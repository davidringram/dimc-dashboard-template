---
import Layout from "../layouts/Layout.astro";
---

<Layout title="David R. Ingram | Fractional CMO">
    <div
        class="min-h-screen bg-[#353c33] flex flex-col items-center justify-center p-4 relative overflow-hidden"
    >
        <div
            class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] pointer-events-none"
        >
        </div>

        <div
            class="relative z-10 w-full max-w-lg bg-[#282e26] border-t-4 border-[#ea580c] shadow-2xl rounded-sm overflow-hidden"
        >
            <div class="bg-[#1f241d] p-8 text-center border-b border-[#353c33]">
                <h1
                    class="text-3xl font-black text-white tracking-tight uppercase"
                >
                    David R. Ingram
                </h1>
                <p
                    class="text-[#ea580c] font-bold text-sm tracking-[0.2em] uppercase mt-1"
                >
                    Fractional CMO Command Center
                </p>
            </div>

            <div class="p-8 text-center space-y-6">
                <p class="text-gray-400 text-xs italic tracking-wide">
                    // RESTRICTED ACCESS // <br />
                    CLIENT OPERATIONS & ANALYTICS PORTAL
                </p>

                <div class="py-4 border-y border-[#353c33] space-y-2">
                    <h2 class="text-lg font-bold text-white uppercase tracking-wider">
                        Client Operations Portal
                    </h2>
                    <p class="text-gray-400 text-xs leading-relaxed">
                        Authorized personnel only. Access active growth dashboards, lead pipelines, and campaign metrics.
                    </p>
                </div>

                <div class="space-y-3 pt-2">
                    <a
                        href="/login"
                        class="block w-full bg-[#ea580c] hover:bg-[#c2410c] text-white font-bold py-3.5 uppercase tracking-widest shadow-lg transition-all transform hover:-translate-y-0.5 rounded-sm text-sm"
                    >
                        Access Client Portal
                    </a>

                    <a
                        href="mailto:david@davidringram.com"
                        class="block w-full bg-[#1f241d] hover:bg-[#353c33] border border-[#353c33] hover:border-[#ea580c] text-gray-300 hover:text-white font-bold py-3 uppercase tracking-wider transition-colors rounded-sm text-xs"
                    >
                        Direct Inquiry // david@davidringram.com
                    </a>
                </div>
            </div>

            <div
                class="bg-[#1f241d] p-4 text-center border-t border-[#353c33] flex justify-between items-center px-8"
            >
                <span class="text-[#353c33] text-[10px] font-mono"
                    >ENCRYPTED // V1.0</span
                >
                <span class="text-gray-500 text-[10px] uppercase font-mono tracking-wider">
                    System Online
                </span>
            </div>
        </div>
    </div>
</Layout>